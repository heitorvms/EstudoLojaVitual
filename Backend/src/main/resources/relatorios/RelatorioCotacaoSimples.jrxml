<jasperReport name="RelatorioCotacaoSimples" language="java" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="40" bottomMargin="40" uuid="7c5d1c35-74b2-4d2a-9b19-1f5a70b644c2">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="id_cotacao" class="java.lang.Long"/>
	<parameter name="distribuidora_nome" class="java.lang.String"/>
	<parameter name="cliente_nome" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
  md.descricao AS material_nome,
  m.quantidade AS quantidade,
  pmc.preco AS preco_unitario,
  (m.quantidade * pmc.preco) AS preco_total
FROM material m
JOIN material_disponivel md ON md.id = m.id_material_disponivel
JOIN preco_material_cotacao pmc ON pmc.id_material = m.id AND pmc.id_cotacao = m.id_cotacao
JOIN distribuidora d ON d.id = pmc.id_distribuidora
WHERE m.id_cotacao = $P{id_cotacao}
  AND ($P{distribuidora_nome} IS NULL OR d.nome = $P{distribuidora_nome})
ORDER BY md.descricao]]></query>
	<field name="material_nome" class="java.lang.String"/>
	<field name="quantidade" class="java.lang.Integer"/>
	<field name="preco_unitario" class="java.lang.Double"/>
	<field name="preco_total" class="java.lang.Double"/>
	<variable name="TOTAL_GERAL" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{preco_total}]]></expression>
	</variable>
